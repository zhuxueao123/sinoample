# Copy this file to .env.cloudflare and fill real values locally.
# Do not commit .env.cloudflare.

# Cloudflare account
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Cloudflare zone
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_DOMAIN=sino-ample.com

# Planned resource names
CLOUDFLARE_PAGES_PROJECT=sino-ample-web
CLOUDFLARE_WORKER_NAME=sino-ample-api
CLOUDFLARE_D1_PREVIEW=sino-ample-preview
CLOUDFLARE_D1_PROD=sino-ample-prod
CLOUDFLARE_R2_BUCKET=sino-ample-media

# Optional custom domains
CLOUDFLARE_WEB_DOMAIN=www.sino-ample.com
CLOUDFLARE_API_DOMAIN=api.sino-ample.com
CLOUDFLARE_MEDIA_DOMAIN=media.sino-ample.com
