{
  "kind": "collectionType",
  "collectionName": "solutions",
  "info": {
    "singularName": "solution",
    "pluralName": "solutions",
    "displayName": "Solution",
    "description": "Business and location-based vending solutions"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "short_description": {
      "type": "text"
    },
    "overview": {
      "type": "richtext"
    },
    "cover_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "pain_points": {
      "type": "json"
    },
    "recommended_products": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::product.product",
      "inversedBy": "recommended_solutions"
    },
    "deployment_notes": {
      "type": "richtext"
    },
    "payment_and_management_notes": {
      "type": "richtext"
    },
    "business_model_notes": {
      "type": "richtext"
    },
    "cta_title": {
      "type": "string"
    },
    "cta_description": {
      "type": "text"
    },
    "sort_order": {
      "type": "integer",
      "default": 0
    },
    "seo_title": {
      "type": "string"
    },
    "seo_description": {
      "type": "text"
    },
    "og_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    }
  }
}
