# Server
HOST=0.0.0.0
PORT=1337

# Secrets
APP_KEYS=toBeModified1,toBeModified2,toBeModified3,toBeModified4
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
ENCRYPTION_KEY=tobemodified

# Local development database
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Upload provider
# Use local for development without Cloudflare credentials.
UPLOAD_PROVIDER=local

# Set UPLOAD_PROVIDER=r2 in production.
# R2_ENDPOINT=https://<cloudflare-account-id>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=sinoample-media
# R2_REGION=auto
# R2_PUBLIC_URL=https://media.sinoample.shop
# R2_ROOT_PATH=cms

# Cloudflare sync
CLOUDFLARE_SYNC_URL=https://api.sinoample.shop
CLOUDFLARE_SYNC_SECRET=

# Production PostgreSQL example
# DATABASE_CLIENT=postgres
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432
# DATABASE_NAME=sinoample_cms
# DATABASE_USERNAME=sinoample
# DATABASE_PASSWORD=change-me
# DATABASE_SSL=false
